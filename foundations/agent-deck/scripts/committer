#!/usr/bin/env bash

set -euo pipefail

usage() {
  printf 'Usage: %s "commit message" "file" ["file" ...]\n' "$(basename "$0")" >&2
  exit 2
}

if [[ $# -lt 2 ]]; then
  usage
fi

commit_message="$1"
shift
files=("$@")

if [[ "$commit_message" != *[![:space:]]* ]]; then
  printf 'Error: commit message must not be empty\n' >&2
  exit 1
fi

current_branch="$(git branch --show-current 2>/dev/null || true)"
if [[ ("$current_branch" == "main" || "$current_branch" == "master") && "${AGENTDECK_ALLOW_MAIN_COMMIT:-0}" != "1" ]]; then
  printf "Error: committing on '%s' is blocked in this repo. Use a custom branch.\n" "$current_branch" >&2
  printf "If intentional, re-run with AGENTDECK_ALLOW_MAIN_COMMIT=1.\n" >&2
  exit 1
fi

for file in "${files[@]}"; do
  if [[ "$file" == "." ]]; then
    printf 'Error: "." is not allowed; list specific paths instead\n' >&2
    exit 1
  fi
done

git restore --staged :/
git add --force -- "${files[@]}"

if git diff --staged --quiet; then
  printf 'Error: no staged changes detected for: %s\n' "${files[*]}" >&2
  exit 1
fi

git commit -m "$commit_message" -- "${files[@]}"
printf 'Committed "%s" with %d files\n' "$commit_message" "${#files[@]}"
